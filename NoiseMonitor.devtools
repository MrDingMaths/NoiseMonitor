                    <!-- The Limit Line -->
                    <div id="vnl-limit-line" class="vnl-limit-line">
                        <span>MAX LEVEL</span>
                    </div>
                    <!-- The Liquid Fill -->
                    <div id="vnl-meter-fill" class="vnl-meter-fill"></div>
                </div>
            </div>

            <!-- Alarm Overlay -->
            <div id="vnl-alarm-overlay" class="vnl-alarm-overlay">

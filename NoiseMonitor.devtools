<script>/**
 * Exam Manager - Interactive Math Exam: alevel-22-ed-na-paper2
 * WordPress Code Snippets Implementation
 * Version: 13
 * 
 * This snippet is specific to exam: alevel-22-ed-na-paper2
 * 
 * IMPORTANT: MathJax is configured to use \( \) and \[ \] delimiters ONLY.
 * Do NOT use $ or $$ in the HTML content.
 */
(function() {
    'use strict';

    const examHash = 'alevel-22-ed-na-paper2';
    const examId = examHash.replace(/-/g, '_');

    /**
     * Configure and load MathJax with robust error handling
     * Handles race conditions and ensures extensions load correctly
     */
    function configureAndLoadMathJax() {
        // Define config object - NO DOLLAR SIGN SUPPORT
        const mjConfig = {
            tex2jax: {
                // CRITICAL: Only \( \) and \[ \] - NO $ delimiters
                inlineMath: [['\\(', '\\)']],
                displayMath: [['\\[', '\\]']],
                processEscapes: true
            },
            TeX: {
                extensions: ["cancel.js", "enclose.js", "AMSmath.js", "AMSsymbols.js"],
                Macros: {
                    require: ['', 1]
                }
            },
            "HTML-CSS": {
                linebreaks: { automatic: true }
            },
            SVG: {
                linebreaks: { automatic: true }
            }
        };

        // Race Condition Handler: If MathJax is ALREADY loaded
        if (window.MathJax && window.MathJax.Hub) {
            window.MathJax.Hub.Config(mjConfig);
            window.MathJax.Hub.Queue(["Typeset", window.MathJax.Hub]);
            return;
        }

        // Injection Handler: If MathJax is MISSING
        const configScript = document.createElement('script');
        configScript.type = 'text/x-mathjax-config';
        configScript.text = "MathJax.Hub.Config(" + JSON.stringify(mjConfig) + ");";
        document.head.appendChild(configScript);

        // Inject library
        const script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.7/MathJax.js?config=TeX-MML-AM_CHTML';
        script.async = true;
        script.onload = function() {
            window.MathJax.Hub.Config(mjConfig);
            window.MathJax.Hub.Queue(["Typeset", window.MathJax.Hub]);
            console.log('MathJax loaded with cancel & enclose extensions');
        };
        script.onerror = function() {
            console.error('Failed to load MathJax');
        };
        document.head.appendChild(script);
    }

    // Create namespaced object
    window['ExamManager_' + examId] = {

        toggle: function(qNum, btnElement) {
            const solutionId = examHash + '-solution-q' + qNum;
            const solution = document.getElementById(solutionId);
            const btn = btnElement;

            if (!solution) {
                console.error('Solution not found:', solutionId);
                return;
            }

            if (solution.style.display === 'none' || solution.style.display === '') {
                solution.style.display = 'block';
                btn.textContent = 'Hide Solution';
                btn.style.background = '#b0bec5';

                if (typeof MathJax !== 'undefined' && MathJax.Hub) {
                    MathJax.Hub.Queue(["Typeset", MathJax.Hub, solution]);
                }
            } else {
                solution.style.display = 'none';
                btn.textContent = 'Show Solution';
                btn.style.background = '#81c784';
            }
        },

        scrollToTop: function(event) {
            if (event) event.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    };

    // Initialization Trigger
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', configureAndLoadMathJax);
    } else {
        configureAndLoadMathJax();
    }

    // Also set up anchor link handling
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');

                if (href === '#' || href === '') {
                    e.preventDefault();
                    window['ExamManager_' + examId].scrollToTop(e);
                } else if (href.startsWith('#' + examHash)) {
                    e.preventDefault();
                    const target = document.querySelector(href);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }
            });
        });

        console.log('ExamManager V13 initialized for:', examHash);
    });

})();</script>

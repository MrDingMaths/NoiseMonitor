</div><script type="module" src="https://mrbartonmaths.com/wp-includes/js/dist/script-modules/block-library/navigation/view.min.js?ver=b0f909c3ec791c383210" id="@wordpress/block-library/navigation/view-js-module" fetchpriority="low" data-wp-router-options="{&quot;loadOnClientNavigation&quot;:true}"></script>
<script>document.addEventListener('DOMContentLoaded', function() {
    
    const HASH = 'VisualNoiseLevel_7xR9p';
    const CONTAINER = document.getElementById(HASH);
    
    if (!CONTAINER) return;

    // --- State ---
    const STATE = {
        isMonitoring: false,
        sensitivity: 50,    // Multiplier for microphone input
        threshold: 70,      // Percent where alarm triggers
        currentVol: 0,
        audioCtx: null,
        analyser: null,
        source: null,
        stream: null,
        rafId: null,
        alarmCooldown: 0    // Prevent flickering
    };

    // --- DOM Elements ---
    const els = {
        views: {
            start: CONTAINER.querySelector('#vnl-view-start'),
            monitor: CONTAINER.querySelector('#vnl-view-monitor')
        },
        controls: {
            activate: CONTAINER.querySelector('#vnl-btn-activate'),
            stop: CONTAINER.querySelector('#vnl-btn-stop'),
            fullscreen: CONTAINER.querySelector('#vnl-btn-fullscreen'),
            sensitivity: CONTAINER.querySelector('#vnl-in-sensitivity'),
            threshold: CONTAINER.querySelector('#vnl-in-threshold')
        },
        visuals: {
            fill: CONTAINER.querySelector('#vnl-meter-fill'),
            limitLine: CONTAINER.querySelector('#vnl-limit-line'),
            emoji: CONTAINER.querySelector('#vnl-emoji-display'),
            stage: CONTAINER.querySelector('.vnl-stage'),
            alarm: CONTAINER.querySelector('#vnl-alarm-overlay')
        }
    };

    // --- LocalStorage ---
    const loadSettings = () => {
        const saved = localStorage.getItem(HASH + '_settings');
        if (saved) {
            const data = JSON.parse(saved);
            STATE.sensitivity = parseInt(data.sens) || 50;
            STATE.threshold = parseInt(data.thresh) || 70;
            els.controls.sensitivity.value = STATE.sensitivity;
            els.controls.threshold.value = STATE.threshold;
            updateThresholdUI();
        }
    };

    const saveSettings = () => {
        localStorage.setItem(HASH + '_settings', JSON.stringify({
            sens: els.controls.sensitivity.value,
            thresh: els.controls.threshold.value
        }));
    };

    // --- Audio Logic ---
    const startAudio = async () => {
        try {
            STATE.stream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
            
            STATE.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            STATE.analyser = STATE.audioCtx.createAnalyser();
            STATE.analyser.fftSize = 256; // Smaller FFT size is faster and sufficient for volume
            STATE.analyser.smoothingTimeConstant = 0.8; // Smooth out jitter
            
            STATE.source = STATE.audioCtx.createMediaStreamSource(STATE.stream);
            STATE.source.connect(STATE.analyser);
            
            STATE.isMonitoring = true;
            els.views.start.classList.remove('active');
            els.views.monitor.classList.add('active');
            
            updateLoop();

        } catch (err) {
            console.error(err);
            alert("Could not access microphone. Please ensure you have allowed permission and are using HTTPS.");
        }
    };

    const stopAudio = () => {
        if (STATE.stream) STATE.stream.getTracks().forEach(track => track.stop());
        if (STATE.audioCtx) STATE.audioCtx.close();
        if (STATE.rafId) cancelAnimationFrame(STATE.rafId);
        
        STATE.isMonitoring = false;
        els.views.monitor.classList.remove('active');
        els.views.start.classList.add('active');
        
        // Reset Visuals
        els.visuals.alarm.classList.remove('active');
        els.visuals.fill.style.height = '0%';
    };

    const getVolume = () => {
        const dataArray = new Uint8Array(STATE.analyser.frequencyBinCount);
        STATE.analyser.getByteFrequencyData(dataArray);
        
        // Calculate average volume level
        let sum = 0;
        for (let i = 0; i < dataArray.length; i++) {
            sum += dataArray[i];
        }
        let average = sum / dataArray.length; // 0 to 255
        
        // Normalize 0-1
        let val = average / 128.0; 
        
        // Apply User Sensitivity (0 to 100 range -> Multiplier 0.5 to 3.0)
        // Sensitivity 0 = requires yelling
        // Sensitivity 100 = picks up a pin drop
        const sensitivityMult = 0.5 + (STATE.sensitivity / 25); 
        val = val * sensitivityMult;

        return Math.min(Math.max(val, 0), 1); // Clamp between 0 and 1
    };

    const updateLoop = () => {
        if (!STATE.isMonitoring) return;

        const vol = getVolume(); // 0.0 to 1.0
        const percentage = vol * 100;
        
        // --- Update Visuals ---
        els.visuals.fill.style.height = `${percentage}%`;
        
        // Scale Emoji based on volume
        const scale = 1 + (vol * 0.5); // 1.0 to 1.5 scale
        els.visuals.emoji.style.transform = `translateX(-50%) scale(${scale})`;

        // --- Logic Stages ---
        const thresh = STATE.threshold;
        
        // Check for Alarm
        if (percentage > thresh) {
            if (STATE.alarmCooldown <= 0) {
                triggerAlarm(true);
            }
        } else {
            if (STATE.alarmCooldown > 0) STATE.alarmCooldown--;
            else triggerAlarm(false);
        }

        // Color Logic (Green -> Yellow -> Red)
        if (percentage > thresh) {
             // Handled by Alarm
        } else if (percentage > (thresh * 0.7)) {
            // Warning Zone
            els.visuals.fill.style.backgroundColor = 'var(--vnl-warn)';
            els.visuals.fill.style.boxShadow = '0 0 20px var(--vnl-warn)';
            els.visuals.emoji.textContent = '😬'; // Worried
            els.visuals.stage.className = 'vnl-stage stage-warn';
        } else {
            // Calm Zone
            els.visuals.fill.style.backgroundColor = 'var(--vnl-calm)';
            els.visuals.fill.style.boxShadow = '0 0 20px var(--vnl-calm)';
            els.visuals.emoji.textContent = '😊'; // Happy
            els.visuals.stage.className = 'vnl-stage';
        }

        STATE.rafId = requestAnimationFrame(updateLoop);
    };

    const triggerAlarm = (isActive) => {
        if (isActive) {
            els.visuals.alarm.classList.add('active');
            STATE.alarmCooldown = 60; // Keep alarm on for ~1 second (60 frames) to prevent flicker
        } else {
            els.visuals.alarm.classList.remove('active');
        }
    };

    const updateThresholdUI = () => {
        // Move the visual line
        els.visuals.limitLine.style.bottom = `${STATE.threshold}%`;
    };

    // --- Event Listeners ---
    
    // Start/Stop
    els.controls.activate.addEventListener('click', startAudio);
    els.controls.stop.addEventListener('click', stopAudio);

    // Inputs
    els.controls.sensitivity.addEventListener('input', (e) => {
        STATE.sensitivity = parseInt(e.target.value);
        saveSettings();
    });

    els.controls.threshold.addEventListener('input', (e) => {
        STATE.threshold = parseInt(e.target.value);
        updateThresholdUI();
        saveSettings();
    });

    // Fullscreen
    els.controls.fullscreen.addEventListener('click', () => {
        if (!document.fullscreenElement) {
            CONTAINER.requestFullscreen().catch(err => console.log(err));
        } else {
            document.exitFullscreen();
        }
    });

    // Init
    loadSettings();
    updateThresholdUI();
});</script><script>
(function() {
  // --- CONFIG & STATE ---
  const HASH = 'mynum4hsl';
  let targetNumber = 0;
  let clues = []; // Array of 3 strings
  let clueStage = 0; // 0=Start, 1=Clue1, 2=Clue2, 3=Clue3, 4=Guessing
  let isGuessingMode = false;

  // --- DOM ELEMENTS ---
  const elWrapper = document.getElementById(HASH + '-wrapper');
  const elGrid = document.getElementById(HASH + '-grid');
  const elModal = document.getElementById(HASH + '-modal');
  const elModalTitle = document.getElementById(HASH + '-modal-title');
  const elModalMsg = document.getElementById(HASH + '-modal-msg');
  const elStartBtn = document.getElementById(HASH + '-start-btn');
  const elActionBtn = document.getElementById(HASH + '-action-btn');
  const elStatus = document.getElementById(HASH + '-status-text');
  const elFsBtn = document.getElementById(HASH + '-fs-btn');

  const elClue1 = document.getElementById(HASH + '-clue-1');
  const elClue2 = document.getElementById(HASH + '-clue-2');
  const elClue3 = document.getElementById(HASH + '-clue-3');

  // --- INIT ---
  function init() {
    elStartBtn.addEventListener('click', startGame);
    elActionBtn.addEventListener('click', advanceStage);
    elFsBtn.addEventListener('click', toggleFullscreen);
    generateGrid();
  }

  function generateGrid() {
    elGrid.innerHTML = '';
    for(let i=1; i<=100; i++) {
      let cell = document.createElement('div');
      cell.className = HASH + '-cell';
      cell.textContent = i;
      cell.dataset.num = i;
      cell.addEventListener('click', handleCellClick);
      elGrid.appendChild(cell);
    }
  }

  // --- GAME FLOW ---
  function startGame() {
    elModal.style.display = 'none';
    resetBoard();
    
    // Attempt to find a target and clues that satisfy all conditions
    let success = false;
    let attempts = 0;
    
    while(!success && attempts < 1000) {
        attempts++;
        targetNumber = Math.floor(Math.random() * 100) + 1;
        
        // Try to find valid clues for this target
        if(generateStrictClues(targetNumber)) {
            success = true;
        }
    }
    
    if(!success) {
        console.error("Could not generate valid game. Retrying...");
        startGame(); // Recurse safe because of randomness, rare to fail 1000 times
        return;
    }

    // Setup UI
    clueStage = 0;
    isGuessingMode = false;
    updateUI();
  }

  function resetBoard() {
    const cells = document.querySelectorAll('.' + HASH + '-cell');
    cells.forEach(c => c.classList.remove(HASH + '-highlight'));
    elGrid.classList.remove(HASH + '-guessing');
    
    [elClue1, elClue2, elClue3].forEach(el => {
      el.classList.remove('active');
      el.querySelector('.mynum4hsl-clue-text').textContent = '...';
    });
    
    // Fix: Ensure action button is visible on restart
    elActionBtn.style.display = 'block';
    elActionBtn.classList.remove('guess-mode');
  }

  function advanceStage() {
    if(clueStage < 3) {
      clueStage++;
      const clueBox = document.getElementById(HASH + '-clue-' + clueStage);
      clueBox.classList.add('active');
      clueBox.querySelector('.mynum4hsl-clue-text').textContent = clues[clueStage-1];
      updateUI();
    } else if (clueStage === 3) {
      clueStage = 4;
      isGuessingMode = true;
      updateUI();
    }
  }

  function updateUI() {
    if(clueStage === 0) {
      elActionBtn.textContent = "Reveal Clue 1";
      elStatus.textContent = "Game started. Click to reveal the first clue.";
    } else if(clueStage === 1) {
      elActionBtn.textContent = "Reveal Clue 2";
      elStatus.textContent = "Highlight numbers that fit the clue.";
    } else if(clueStage === 2) {
      elActionBtn.textContent = "Reveal Clue 3";
      elStatus.textContent = "Narrow it down further. There are multiple possibilities left.";
    } else if(clueStage === 3) {
      elActionBtn.textContent = "I'm ready to guess!";
      elStatus.textContent = "You should have exactly one number left!";
    } else if(clueStage === 4) {
      elActionBtn.style.display = 'none'; // Hide button for guessing
      elStatus.textContent = "Click the correct number on the grid!";
      elGrid.classList.add(HASH + '-guessing');
    }
  }

  function handleCellClick(e) {
    const num = parseInt(e.target.dataset.num);
    if(isGuessingMode) {
      checkWin(num);
    } else {
      e.target.classList.toggle(HASH + '-highlight');
    }
  }

  function checkWin(pickedNum) {
    if(pickedNum === targetNumber) {
      celebrate();
      elModalTitle.textContent = "Correct! 🎉";
      elModalMsg.innerHTML = `The number was <b>${targetNumber}</b>.<br>Great logic skills!`;
      elStartBtn.textContent = "Play Again";
      setTimeout(() => { elModal.style.display = 'flex'; }, 1000);
    } else {
      alert(`Wrong! You picked ${pickedNum}. Try again.`);
    }
  }

  // --- LOGIC ENGINE ---
  
  // Helper: Checks if number matches a clue object
  function matches(n, clue) {
    if(clue.type === 'mult') return n % clue.val === 0;
    if(clue.type === 'range') return n > clue.min && n < clue.max;
    if(clue.type === 'gt') return n > clue.val;
    if(clue.type === 'lt') return n < clue.val;
    if(clue.type === 'sum') return n.toString().split('').map(Number).reduce((a,b)=>a+b,0) === clue.val;
    if(clue.type === 'diff') {
        if(n < 10) return false;
        let d = n.toString().split('').map(Number);
        return Math.abs(d[0] - d[1]) === clue.val;
    }
    return false;
  }

  // Helper: Count how many numbers (1-100) match a list of clues
  function countCandidates(clueList) {
    let count = 0;
    for(let i=1; i<=100; i++) {
        let fit = true;
        for(let c of clueList) {
            if(!matches(i, c)) { fit = false; break; }
        }
        if(fit) count++;
    }
    return count;
  }

  function generateStrictClues(target) {
    // 1. POOL 1: Times Tables
    let pool1 = [];
    for(let i=2; i<=12; i++) {
        if(target % i === 0) pool1.push({ type: 'mult', val: i, text: `My number is in the ${i} times table.` });
    }
    if(pool1.length === 0) return false;

    // 2. POOL 2: Range / Size
    let pool2 = [];
    let min = Math.max(1, target - Math.floor(Math.random()*15 + 5));
    let max = Math.min(100, target + Math.floor(Math.random()*15 + 5));
    pool2.push({ type: 'range', min: min, max: max, text: `My number is between ${min} and ${max}.` });
    if(target > 15) pool2.push({ type: 'gt', val: target - Math.floor(Math.random()*20+1), text: `My number is greater than ${target - Math.floor(Math.random()*20+1)}.` });
    if(target < 85) pool2.push({ type: 'lt', val: target + Math.floor(Math.random()*20+1), text: `My number is less than ${target + Math.floor(Math.random()*20+1)}.` });
    
    // 3. POOL 3: Digits
    let pool3 = [];
    let digits = target.toString().split('').map(Number);
    let sum = digits.reduce((a,b)=>a+b,0);
    pool3.push({ type: 'sum', val: sum, text: `The sum of the digits is ${sum}.` });
    if(target > 9) {
        let diff = Math.abs(digits[0] - digits[1]);
        pool3.push({ type: 'diff', val: diff, text: `The difference between the digits is ${diff}.` });
    }

    // 4. FIND VALID COMBINATION
    // Shuffle pools
    pool1.sort(() => Math.random() - 0.5);
    pool2.sort(() => Math.random() - 0.5);
    pool3.sort(() => Math.random() - 0.5);

    for(let c1 of pool1) {
        for(let c2 of pool2) {
            
            // CHECK AMBIGUITY after Clue 2
            // We require that Clue 1 + Clue 2 results in > 1 candidate
            let candidatesAfter2 = countCandidates([c1, c2]);
            if(candidatesAfter2 <= 1) continue; // Too easy, skip this pair

            for(let c3 of pool3) {
                // CHECK UNIQUENESS after Clue 3
                let candidatesAfter3 = countCandidates([c1, c2, c3]);
                
                if(candidatesAfter3 === 1) {
                    // Valid Game Found!
                    clues = [c1.text, c2.text, c3.text];
                    return true;
                }
            }
        }
    }

    return false; // No combination worked for this target
  }

  // --- EXTRAS ---
  function celebrate() {
    const colors = ['#e74c3c', '#f1c40f', '#2ecc71', '#3498db', '#9b59b6'];
    for(let i=0; i<50; i++) {
      let c = document.createElement('div');
      c.className = 'mynum4hsl-confetti';
      c.style.backgroundColor = colors[Math.floor(Math.random()*colors.length)];
      c.style.left = Math.random() * 100 + '%';
      c.style.animationDuration = (Math.random() * 2 + 1) + 's';
      elWrapper.appendChild(c);
      setTimeout(() => c.remove(), 3000);
    }
  }

  function toggleFullscreen() {
    if (!document.fullscreenElement) {
        if(elWrapper.requestFullscreen) elWrapper.requestFullscreen();
        else if(elWrapper.webkitRequestFullscreen) elWrapper.webkitRequestFullscreen();
        else if(elWrapper.msRequestFullscreen) elWrapper.msRequestFullscreen();
    } else {
        if(document.exitFullscreen) document.exitFullscreen();
        else if(document.webkitExitFullscreen) document.webkitExitFullscreen();
        else if(document.msExitFullscreen) document.msExitFullscreen();
    }
  }

  init();

})();
</script><script>// ═══════════════════════════════════════════════════════════════
// SUPER 8S: Year 9 Essential Skills
// Hash: y9es_k7m3_updated_v2
// ═══════════════════════════════════════════════════════════════

(function() {

// ─── STATE ───────────────────────────────────────────────────────
const y9es_k7m3_state = {
    currentView: 'menu',
    selectedSkills: [],
    currentQuestions: [],
    focusBoxQuestion: null,
    focusBoxShowAnswer: false,
    focusBoxShowWorking: false,
    showAllAnswers: false,
    timer: {
        totalSeconds: 0,
        remainingSeconds: 0,
        isRunning: false,
        isPaused: false,
        intervalId: null,
        isFlashing: false
    }
};

// ─── NUMBER FORMATTING HELPERS ───────────────────────────────────
function y9es_k7m3_formatPlainNumber(num) {
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
}

function y9es_k7m3_formatMathNumber(num) {
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, "{,}");
}

// ─── GCD/LCM HELPERS ─────────────────────────────────────────────
function y9es_k7m3_gcd(a, b) {
    a = Math.abs(a);
    b = Math.abs(b);
    while (b) {
        const t = b;
        b = a % b;
        a = t;
    }
    return a;
}

function y9es_k7m3_lcm(a, b) {
    return Math.abs(a * b) / y9es_k7m3_gcd(a, b);
}

function y9es_k7m3_areCoprime(a, b) {
    return y9es_k7m3_gcd(a, b) === 1;
}

// ─── FRACTION SIMPLIFIER ─────────────────────────────────────────
function y9es_k7m3_simplifyFraction(num, den) {
    const g = y9es_k7m3_gcd(num, den);
    return { num: num / g, den: den / g };
}

// ─── SKILLS ARRAY ────────────────────────────────────────────────
const y9es_k7m3_skills = [
    // ═══ CATEGORY 0: Algebra: Straight line graphs ═══
    {
        id: 0,
        category: "Algebra: Straight line graphs",
        title: "Identify gradient from y = mx + c",
        description: "Identify the gradient from an equation in y = mx + c form.",
        generator: () => {
            // m from -9 to 9 excluding 0
            let m;
            do {
                m = Math.floor(Math.random() * 19) - 9;
            } while (m === 0);
            
            // c from -12 to 12, including 0
            let c;
            do {
                c = Math.floor(Math.random() * 25) - 12;
            } while (c === m);
            
            // Format coefficient: never write 1x or -1x
            const mStr = m === 1 ? 'x' : m === -1 ? '-x' : `${m}x`;
            
            // Build equation string, never showing +0 or -0
            // Logic avoids "y = 2x + -3", converts to "y = 2x - 3"
            let equation;
            if (c === 0) {
                equation = `y = ${mStr}`;
            } else if (c > 0) {
                // Sometimes put c first: y = 5 + 2x
                if (Math.random() < 0.3) {
                    equation = `y = ${c} + ${mStr}`;
                } else {
                    equation = `y = ${mStr} + ${c}`;
                }
            } else {
                equation = `y = ${mStr} - ${Math.abs(c)}`;
            }
            
            return {
                q: `<span class="q-block">What is the gradient of</span><span class="q-block">\\( ${equation} \\text{?} \\)</span>`,
                a: `${m}`,
                w: [
                    { text: "The equation is in the form y = mx + c.", math: `y = mx + c` },
                    { text: "The gradient m is the coefficient of x.", math: `m = ${m}` },
                    { text: "So the gradient is:", math: `${m}` }
                ]
            };
        }
    },
    {
        id: 1,
        category: "Algebra: Straight line graphs",
        title: "Identify y-intercept from y = mx + c",
        description: "Identify the y-intercept from an equation in y = mx + c form.",
        generator: () => {
            const m = Math.floor(Math.random() * 8) + 2; // 2 to 9
            // c from -12 to 12, including 0
            let c;
            do {
                c = Math.floor(Math.random() * 25) - 12;
            } while (c === m);
            
            // Format coefficient: never write 1x
            const mStr = m === 1 ? 'x' : m === -1 ? '-x' : `${m}x`;
            
            // Build equation, never showing +0 or -0
            let equation;
            if (c === 0) {
                equation = `y = ${mStr}`;
            } else if (c > 0) {
                // Sometimes put c first
                if (Math.random() < 0.3) {
                    equation = `y = ${c} + ${mStr}`;
                } else {
                    equation = `y = ${mStr} + ${c}`;
                }
            } else {
                equation = `y = ${mStr} - ${Math.abs(c)}`;
            }
            
            return {
                q: `<span class="q-block">What is the y-intercept of</span><span class="q-block">\\( ${equation} \\text{?} \\)</span>`,
                a: `\\( (0, ${c}) \\)`,
                w: [
                    { text: "The equation is in the form y = mx + c.", math: `y = mx + c` },
                    { text: "The y-intercept is where the line crosses the y-axis (when x = 0).", math: `c = ${c}` },
                    { text: "So the y-intercept is:", math: `(0, ${c})` }
                ]
            };
        }
    },
    {
        id: 2,
        category: "Algebra: Straight line graphs",
        title: "Write equation of parallel line",
        description: "Write the equation of a line parallel to a given line through a y-intercept.",
        generator: () => {
            const m = Math.floor(Math.random() * 7) + 2; // 2 to 8
            const origC = Math.floor(Math.random() * 21) - 10;
            let newC;
            do {
                newC = Math.floor(Math.random() * 21) - 10;
            } while (newC === origC);
            
            const mStr = m === 1 ? 'x' : m === -1 ? '-x' : `${m}x`;
            
            let origEq;
            if (origC === 0) {
                origEq = `y = ${mStr}`;
            } else if (origC > 0) {
                origEq = `y = ${mStr} + ${origC}`;
            } else {
                origEq = `y = ${mStr} - ${Math.abs(origC)}`;
            }
            
            let ansEq;
            if (newC === 0) {
                ansEq = `y = ${mStr}`;
            } else if (newC > 0) {
                ansEq = `y = ${mStr} + ${newC}`;
            } else {
                ansEq = `y = ${mStr} - ${Math.abs(newC)}`;
            }
            
            return {
                q: `<span class="q-block">Write the equation of a line parallel to \\( ${origEq} \\)</span><span class="q-block">that passes through \\( (0, ${newC}) \\)</span>`,
                a: `\\( ${ansEq} \\)`,
                w: [
                    { text: "Parallel lines have the same gradient.", math: `m = ${m}` },
                    { text: "The line passes through (0, " + newC + "), so the y-intercept is:", math: `c = ${newC}` },
                    { text: "Using y = mx + c:", math: ansEq }
                ]
            };
        }
    },
	// ═══ CATEGORY 1: Algebra: Equations ═══
    {
        id: 3,
        category: "Algebra: Equations",
        title: "Solve two-step equation",
        description: "Solve a two-step linear equation (multiplication or division).",
        generator: () => {
            const x = Math.floor(Math.random() * 10) + 1; // Answer always positive integer 1-10
            
            const type = Math.floor(Math.random() * 2); // 0 = Multiplication, 1 = Division
            
            if (type === 0) {
                // Multiplication: ax + b = c
                const a = Math.floor(Math.random() * 8) + 2; 
                let b = Math.floor(Math.random() * 19) - 9; // -9 to 9
                if (b === 0) b = 5;
                const result = a * x + b;
                
                const sign = b > 0 ? '+' : '-';
                const eq = `${a}x ${sign} ${Math.abs(b)} = ${result}`;
                
                return {
                    q: `<span class="q-block">Solve</span><span class="q-block">\\( ${eq} \\)</span>`,
                    a: `\\( x = ${x} \\)`,
                    w: [
                        { text: b > 0 ? `Subtract ${b} from both sides:` : `Add ${Math.abs(b)} to both sides:`, math: `${a}x = ${result - b}` },
                        { text: `Divide by ${a}:`, math: `x = ${x}` }
                    ]
                };
            } else {
                // Division
                const divType = Math.random() < 0.5 ? 'separate' : 'all';
                const a = Math.floor(Math.random() * 4) + 2; // Denominator 2-5
                let b = Math.floor(Math.random() * 19) - 9;
                if (b === 0) b = 3;
                
                if (divType === 'separate') {
                    // x/a + b = c
                    const result = (x / a) + b;
                    // Note: To ensure result is nice for display (though question asks for int answer, intermediate might not be int unless we reverse engineered nicely).
                    // Actually, let's reverse engineer from result to x.
                    // But requirement is x is positive integer. 
                    // Let's stick to x is int. Result might be decimal if x not div by a? 
                    // To keep equations clean: let's ensure x is a multiple of a.
                    const xMult = x * a; // New X that is multiple of a
                    const res = (xMult / a) + b;
                    
                    const sign = b > 0 ? '+' : '-';
                    const eq = `\\frac{x}{${a}} ${sign} ${Math.abs(b)} = ${res}`;
                    
                    return {
                        q: `<span class="q-block">Solve</span><span class="q-block">\\( ${eq} \\)</span>`,
                        a: `\\( x = ${xMult} \\)`,
                        w: [
                            { text: b > 0 ? `Subtract ${b} from both sides:` : `Add ${Math.abs(b)} to both sides:`, math: `\\frac{x}{${a}} = ${res - b}` },
                            { text: `Multiply by ${a}:`, math: `x = ${(res - b) * a}` }
                        ]
                    };
                } else {
                    // (x + b) / a = c
                    // We need result to be integer usually for these questions to look nice? 
                    // Let's generate result C first, then find X.
                    const c = Math.floor(Math.random() * 10) + 2;
                    // (x + b)/a = c  => x + b = ac => x = ac - b
                    // We need x to be positive integer.
                    // ac - b > 0 => ac > b.
                    let targetVal;
                    do {
                         targetVal = a * c - b;
                    } while (targetVal <= 0); // Regenerate if x becomes negative
                    
                    const sign = b > 0 ? '+' : '-';
                    const eq = `\\frac{x ${sign} ${Math.abs(b)}}{${a}} = ${c}`;
                    
                    return {
                        q: `<span class="q-block">Solve</span><span class="q-block">\\( ${eq} \\)</span>`,
                        a: `\\( x = ${targetVal} \\)`,
                        w: [
                            { text: `Multiply by ${a}:`, math: `x ${sign} ${Math.abs(b)} = ${c * a}` },
                            { text: b > 0 ? `Subtract ${b}:` : `Add ${Math.abs(b)}:`, math: `x = ${targetVal}` }
                        ]
                    };
                }
            }
        }
    },
    {
        id: 4,
        category: "Algebra: Equations",
        title: "Solve equation with brackets",
        description: "Solve a linear equation involving brackets.",
        generator: () => {
            let x;
            do {
                x = Math.floor(Math.random() * 12) + 1; // Positive integer
            } while (x === 0);
            
            const a = Math.floor(Math.random() * 5) + 2; // 2 to 6
            let b = Math.floor(Math.random() * 9) + 1; // 1 to 9
            
            // Equal frequency addition/subtraction
            if (Math.random() < 0.5) b = -b;
            
            const result = a * (x + b);
            
            const sign = b > 0 ? '+' : '-';
            const equation = `${a}(x ${sign} ${Math.abs(b)}) = ${result}`;
            
            return {
                q: `<span class="q-block">Solve</span><span class="q-block">\\( ${equation} \\)</span>`,
                a: `\\( x = ${x} \\)`,
                w: [
                    { text: "Divide both sides by " + a + ":", math: `x ${sign} ${Math.abs(b)} = ${result / a}` },
                    { text: b > 0 ? `Subtract ${b} from both sides:` : `Add ${Math.abs(b)} to both sides:`, math: `x = ${x}` }
                ]
            };
        }
    },
    {
        id: 5,
        category: "Algebra: Equations",
        title: "Solve equation with unknowns on both sides",
        description: "Solve a linear equation with the variable on both sides.",
        generator: () => {
            const x = Math.floor(Math.random() * 10) + 1; // Always positive integer
            
            // 25% chance of negative coefficient type: 3 - 2x = 4x + 5
            const isNegType = Math.random() < 0.25;
            
            if (isNegType) {
                // Form: A - Bx = Cx + D
                // Move x's: A - D = Cx + Bx => A - D = (C+B)x
                const B = Math.floor(Math.random() * 4) + 2;
                const C = Math.floor(Math.random() * 4) + 2;
                const totalX = B + C;
                const diff = totalX * x; // This is A - D
                
                // Pick D, calculate A
                const D = Math.floor(Math.random() * 10) + 1;
                const A = D + diff;
                
                // Form equation string: A - Bx = Cx + D
                // Or swap sides: Cx + D = A - Bx
                const swap = Math.random() < 0.5;
                const lhs = `${A} - ${B}x`;
                const rhs = `${C}x + ${D}`;
                
                const equation = swap ? `${rhs} = ${lhs}` : `${lhs} = ${rhs}`;
                
                return {
                    q: `<span class="q-block">Solve</span><span class="q-block">\\( ${equation} \\)</span>`,
                    a: `\\( x = ${x} \\)`,
                    w: [
                        { text: `Add ${B}x to both sides:`, math: `${A} = ${totalX}x + ${D}` },
                        { text: `Subtract ${D} from both sides:`, math: `${A-D} = ${totalX}x` },
                        { text: `Divide by ${totalX}:`, math: `x = ${x}` }
                    ]
                };
            } else {
                // Standard: Ax + B = Cx + D where A > C
                let A = Math.floor(Math.random() * 5) + 4; // 4 to 8
                let C = Math.floor(Math.random() * (A - 2)) + 2; // Less than A
                
                // Equal chance of add/subtract for constants
                let B = Math.floor(Math.random() * 10) + 1;
                if (Math.random() < 0.5) B = -B;
                
                // Calculate D needed for valid x
                // Ax + B = Cx + D => (A-C)x + B = D
                const D = (A - C) * x + B;
                
                const signB = B >= 0 ? '+' : '-';
                const signD = D >= 0 ? '+' : '-';
                
                const lhs = `${A}x ${signB} ${Math.abs(B)}`;
                const rhs = `${C}x ${signD} ${Math.abs(D)}`;
                
                // Randomly swap sides
                const equation = Math.random() < 0.5 ? `${lhs} = ${rhs}` : `${rhs} = ${lhs}`;
                
                return {
                    q: `<span class="q-block">Solve</span><span class="q-block">\\( ${equation} \\)</span>`,
                    a: `\\( x = ${x} \\)`,
                    w: [
                        { text: `Subtract ${C}x from both sides:`, math: `${A-C}x ${signB} ${Math.abs(B)} = ${D}` },
                        { text: B >= 0 ? `Subtract ${B} from both sides:` : `Add ${Math.abs(B)} from both sides:`, math: `${A-C}x = ${D - B}` },
                        { text: `Divide by ${A-C}:`, math: `x = ${x}` }
                    ]
                };
            }
        }
    },
	{
        id: 6,
        category: "Algebra: Equations",
        title: "Solve simple inequality",
        description: "Solve a linear inequality and express the solution.",
        generator: () => {
            const boundary = Math.floor(Math.random() * 9) + 2;
            const a = Math.floor(Math.random() * 5) + 2;
            let b = Math.floor(Math.random() * 10) + 1;
            
            // Equal frequency add/subtract
            if (Math.random() < 0.5) b = -b;
            
            const rightSide = a * boundary + b;
            
            const isLessThan = Math.random() < 0.5;
            const symbol = isLessThan ? '<' : '>';
            
            const sign = b > 0 ? '+' : '-';
            const equation = `${a}x ${sign} ${Math.abs(b)} ${symbol} ${rightSide}`;
            
            return {
                q: `<span class="q-block">Solve</span><span class="q-block">\\( ${equation} \\)</span>`,
                a: `\\( x ${symbol} ${boundary} \\)`,
                w: [
                    { text: b > 0 ? "Subtract " + b + " from both sides:" : "Add " + Math.abs(b) + " to both sides:", math: `${a}x ${symbol} ${rightSide - b}` },

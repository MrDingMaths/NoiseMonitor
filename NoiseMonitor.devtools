    {
        id: 9,
        category: "Algebra: Expressions",
        title: "Expand double brackets",
        description: "Expand and simplify the product of two binomials.",
        generator: () => {
            let a = Math.floor(Math.random() * 9) + 1; 
            let b = Math.floor(Math.random() * 9) + 1; 
            
            if (Math.random() < 0.25) {
                if (Math.random() < 0.5) a = -a; else b = -b;
            } else if (Math.random() < 0.25) {
                // Occasional double negative for variety
                a = -a; b = -b;
            }
            
            const middle = a + b;
            const constant = a * b;
            
            const bracket1 = a >= 0 ? `x + ${a}` : `x - ${Math.abs(a)}`;
            const bracket2 = b >= 0 ? `x + ${b}` : `x - ${Math.abs(b)}`;
            
            let middleStr;
            if (middle === 0) middleStr = "";
            else if (middle === 1) middleStr = "+ x";
            else if (middle === -1) middleStr = "- x";
            else if (middle > 0) middleStr = `+ ${middle}x`;
            else middleStr = `- ${Math.abs(middle)}x`;
            
            let answer;
            if (middle === 0) {
                 answer = constant >= 0 ? `x^2 + ${constant}` : `x^2 - ${Math.abs(constant)}`;
            } else {
                 answer = constant >= 0 ? `x^2 ${middleStr} + ${constant}` : `x^2 ${middleStr} - ${Math.abs(constant)}`;
            }
            
            return {
                q: `<span class="q-block">Expand and simplify</span><span class="q-block">\\( (${bracket1})(${bracket2}) \\)</span>`,
                a: `\\( ${answer} \\)`,
                w: [
                    { text: "Multiply first terms:", math: `x \\times x = x^2` },
                    { text: "Multiply outer terms:", math: `x \\times ${b >= 0 ? b : '(' + b + ')'} = ${b === 1 ? 'x' : b === -1 ? '-x' : b + 'x'}` },
                    { text: "Multiply inner terms:", math: `${a >= 0 ? a : '(' + a + ')'} \\times x = ${a === 1 ? 'x' : a === -1 ? '-x' : a + 'x'}` },
                    { text: "Multiply last terms:", math: `${a} \\times ${b} = ${constant}` },
                    { text: "Collect like terms:", math: answer }
                ]
            };
        }

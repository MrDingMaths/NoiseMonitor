<style>
/* Dropdown backgrounds */
.wp-block-navigation__submenu-container {
    background-color: #000000 !important;
    border: 1px solid #333 !important;
    border-radius: 8px !important;
    padding: 4px 0 !important;
    min-width: 220px !important;
}

/* Dropdown link colour */
.wp-block-navigation__submenu-container .wp-block-navigation-item__content {
    color: #ffffff !important;
    padding: 6px 16px !important;
}
.wp-block-navigation__submenu-container .wp-block-navigation-item__content:hover {
    color: #93c5fd !important;
}

/* Nested submenu labels (Numeracy, Skills, etc.) */
.wp-block-navigation__submenu-container .wp-block-navigation__submenu-container {
    background-color: #111827 !important;
    border: 1px solid #374151 !important;
}

/* Support link accent colour */
.wp-block-navigation-item__content[href*="patreon"] {
    color: #f9a8d4 !important;
}
.wp-block-navigation-item__content[href*="patreon"]:hover {
    color: #f472b6 !important;
}

/* ===== Mobile menu: collapse submenus by default ===== */
.wp-block-navigation__responsive-container.is-menu-open
  .wp-block-navigation__submenu-container {
    display: none !important;
}

.wp-block-navigation__responsive-container.is-menu-open
  .has-child.mbm-submenu-open > .wp-block-navigation__submenu-container {
    display: flex !important;
    flex-direction: column;
}

/* Chevron indicator for expandable items */
.wp-block-navigation__responsive-container.is-menu-open
  .has-child > .wp-block-navigation-item__content::after {
    content: ' ▸';
    font-size: 0.75em;
    opacity: 0.5;
    transition: transform 0.2s ease;
    display: inline-block;
}

.wp-block-navigation__responsive-container.is-menu-open
  .has-child.mbm-submenu-open > .wp-block-navigation-item__content::after {
    transform: rotate(90deg);
    opacity: 0.8;
}
</style>

<script>
(function() {
  function initMobileMenu() {
    var container = document.querySelector('.wp-block-navigation__responsive-container');
    if (!container) return;

    container.addEventListener('click', function(e) {
      // Only act inside the open mobile overlay
      if (!container.classList.contains('is-menu-open')) return;

      // Find the closest parent navigation item with children
      var link = e.target.closest('.has-child > .wp-block-navigation-item__content');
      if (!link) return;

      var parentItem = link.parentElement;
      // Only intercept if this item actually has a submenu (not a real link)
      var submenu = parentItem.querySelector(':scope > .wp-block-navigation__submenu-container');
      if (!submenu) return;

      // If the link has a real URL (not just "#" or empty), still toggle instead of navigating
      e.preventDefault();
      e.stopPropagation();

      // Close sibling submenus at the same level
      var siblings = parentItem.parentElement.querySelectorAll(':scope > .has-child.mbm-submenu-open');
      siblings.forEach(function(sib) {
        if (sib !== parentItem) sib.classList.remove('mbm-submenu-open');
      });

      // Toggle this submenu
      parentItem.classList.toggle('mbm-submenu-open');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
})();
</script>

</div>

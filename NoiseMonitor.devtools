}

@keyframes vnl-wave { 0%, 100% { transform: rotate(0deg); } 25% { transform: rotate(15deg); } 75% { transform: rotate(-15deg); } }
@keyframes vnl-flash { 0%, 100% { background: rgba(220, 38, 38, 0.85); } 50% { background: rgba(220, 38, 38, 0.95); } }
</style>

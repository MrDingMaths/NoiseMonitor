            let constant = Math.floor(Math.random() * 9) + 1; 
            const isNeg = Math.random() < 0.4;
            if (isNeg) constant = -constant;
            
            const insideTerm = constant >= 0 ? `${xCoef === 1 ? '' : xCoef}x + ${constant}` : `${xCoef === 1 ? '' : xCoef}x - ${Math.abs(constant)}`;
            const resultX = mult * xCoef;
            const resultConst = mult * constant;
            const answer = resultConst >= 0 ? `${resultX}x + ${resultConst}` : `${resultX}x - ${Math.abs(resultConst)}`;
            
            return {

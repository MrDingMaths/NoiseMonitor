                answer = `£${total}`;
                working = [
                    { text: givenPerson + "'s share represents " + givenPart + " parts:", math: `${givenPart} \\text{ parts} = £${shareValue}` },
                    { text: "Find the value of one part:", math: `1 \\text{ part} = £${shareValue} \\div ${givenPart} = £${multiplier}` },
                    { text: "Total parts = " + (a + b) + ", so total is:", math: `${a + b} \\times ${multiplier} = £${total}` }
                ];
            } else {
                question = `<span class="q-block">Mo and Jo share money in the ratio ${a} : ${b}.</span><span class="q-block">${givenPerson} gets £${shareValue}. How much does ${otherPerson} get?</span>`;
                answer = `£${otherShareValue}`;
                working = [
                    { text: givenPerson + "'s share represents " + givenPart + " parts:", math: `${givenPart} \\text{ parts} = £${shareValue}` },
                    { text: "Find the value of one part:", math: `1 \\text{ part} = £${shareValue} \\div ${givenPart} = £${multiplier}` },
                    { text: otherPerson + " gets " + otherPart + " parts:", math: `${otherPart} \\times ${multiplier} = £${otherShareValue}` }
                ];
            }
            
            return { q: question, a: answer, w: working };
        }
    },
    
    // ═══ CATEGORY 9: Rates: Speed distance time ═══
    {
        id: 26,
        category: "Rates: Speed distance time",
        title: "Calculate speed",
        description: "Calculate average speed given distance and time.",
        generator: () => {
            const speeds = [20, 25, 30, 35, 40, 45, 50, 55, 60, 65, 70, 75, 80];
            const times = [2, 3, 4, 5, 6];
            
            const speed = speeds[Math.floor(Math.random() * speeds.length)];
            const time = times[Math.floor(Math.random() * times.length)];
            const distance = speed * time;
            
            return {
                q: `<span class="q-block">A car travels ${distance} miles in ${time} hours.</span><span class="q-block">Find the speed</span>`,
                a: `${speed} mph`,
                w: [
                    { text: "Speed = Distance ÷ Time:", math: `\\text{Speed} = \\frac{\\text{Distance}}{\\text{Time}}` },
                    { text: "Substitute values:", math: `\\text{Speed} = ${distance} \\div ${time} = ${speed} \\text{ mph}` }
                ]
            };
        }
    },
    {
        id: 27,
        category: "Rates: Speed distance time",
        title: "Calculate distance",
        description: "Calculate distance given speed and time.",
        generator: () => {
            const speeds = [30, 40, 50, 60, 70, 80, 90, 100, 120];
            const times = [1.5, 2, 2.5, 3, 3.5, 4, 5];
            
            const speed = speeds[Math.floor(Math.random() * speeds.length)];
            const time = times[Math.floor(Math.random() * times.length)];
            const distance = speed * time;
            
            return {
                q: `<span class="q-block">A train travels at ${speed} mph for ${time} hours.</span><span class="q-block">How far does it travel?</span>`,
                a: `${distance} miles`,
                w: [
                    { text: "Distance = Speed × Time:", math: `\\text{Distance} = \\text{Speed} \\times \\text{Time}` },
                    { text: "Substitute values:", math: `\\text{Distance} = ${speed} \\times ${time} = ${distance} \\text{ miles}` }
                ]
            };
        }
    },
    {
        id: 28,
        category: "Rates: Speed distance time",
        title: "Calculate time",
        description: "Calculate time given distance and speed.",
        generator: () => {
            const timeValues = [1.5, 2, 2.5, 3, 3.5, 4, 4.5, 5, 6];
            const speeds = [10, 12, 15, 20, 25, 30, 40, 50, 60];
            
            const time = timeValues[Math.floor(Math.random() * timeValues.length)];
            const speed = speeds[Math.floor(Math.random() * speeds.length)];
            const distance = speed * time;
            
            return {
                q: `<span class="q-block">A cyclist travels ${distance}km at ${speed}km/h.</span><span class="q-block">How long does the journey take?</span>`,
                a: `${time} hours`,
                w: [
                    { text: "Time = Distance ÷ Speed:", math: `\\text{Time} = \\frac{\\text{Distance}}{\\text{Speed}}` },
                    { text: "Substitute values:", math: `\\text{Time} = ${distance} \\div ${speed} = ${time} \\text{ hours}` }
                ]
            };
        }
    },
	// ═══ CATEGORY 10: Probability ═══
    {
        id: 29,
        category: "Probability",
        title: "Single event probability",
        description: "Calculate the probability of a single event.",
        generator: () => {
            const scenarios = [
                { context: "A fair dice is rolled", total: 6, events: [
                    { desc: "rolling a 6", favorable: 1 },
                    { desc: "rolling an even number", favorable: 3 },
                    { desc: "rolling an odd number", favorable: 3 },
                    { desc: "rolling a number greater than 4", favorable: 2 },
                    { desc: "rolling a number less than 3", favorable: 2 },
                    { desc: "rolling a number greater than 2", favorable: 4 }
                ]},
                { context: "A fair coin is flipped", total: 2, events: [
                    { desc: "getting heads", favorable: 1 },
                    { desc: "getting tails", favorable: 1 }
                ]},
                { context: "A spinner has 8 equal sections numbered 1-8. It is spun once", total: 8, events: [
                    { desc: "landing on an even number", favorable: 4 },
                    { desc: "landing on a number greater than 5", favorable: 3 },
                    { desc: "landing on a prime number", favorable: 4 },
                    { desc: "landing on a number less than 4", favorable: 3 }
                ]}
            ];
            
            const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
            const event = scenario.events[Math.floor(Math.random() * scenario.events.length)];
            
            const simplified = y9es_k7m3_simplifyFraction(event.favorable, scenario.total);
            
            return {
                q: `<span class="q-block">${scenario.context}.</span><span class="q-block">What is the probability of ${event.desc}?</span>`,
                a: `\\( \\frac{${simplified.num}}{${simplified.den}} \\)`,
                w: [
                    { text: "Count favorable outcomes:", math: `${event.favorable}` },
                    { text: "Count total outcomes:", math: `${scenario.total}` },
                    { text: "Probability = favorable ÷ total:", math: `\\frac{${event.favorable}}{${scenario.total}}` + (event.favorable !== simplified.num ? ` = \\frac{${simplified.num}}{${simplified.den}}` : '') }
                ]
            };
        }
    },
    {
        id: 30,
        category: "Probability",
        title: "Expected outcomes",
        description: "Calculate the expected frequency over multiple trials.",
        generator: () => {
            const scenarios = [
                { context: "A spinner has 5 equal sections numbered 1-5", prob: { num: 2, den: 5 }, event: "an even number" },
                { context: "A spinner has 4 equal sections numbered 1-4", prob: { num: 2, den: 4 }, event: "an odd number" },
                { context: "A fair dice is rolled", prob: { num: 1, den: 6 }, event: "a 3" },
                { context: "A fair dice is rolled", prob: { num: 2, den: 6 }, event: "a number greater than 4" },
                { context: "A spinner has 8 equal sections numbered 1-8", prob: { num: 4, den: 8 }, event: "an even number" }
            ];
            
            const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
            const trials = scenario.prob.den * (Math.floor(Math.random() * 16) + 5);
            const expected = trials * scenario.prob.num / scenario.prob.den;
            
            return {
                q: `<span class="q-block">${scenario.context}. It is spun ${trials} times.</span><span class="q-block">How many times would you expect ${scenario.event}?</span>`,
                a: `${expected}`,
                w: [
                    { text: "Find the probability:", math: `P = \\frac{${scenario.prob.num}}{${scenario.prob.den}}` },
                    { text: "Multiply by the number of trials:", math: `${trials} \\times \\frac{${scenario.prob.num}}{${scenario.prob.den}} = ${expected}` }
                ]
            };
        }
    },
    {
        id: 31,
        category: "Probability",
        title: "Combined probability (AND)",
        description: "Calculate the probability of two independent events both occurring.",
        generator: () => {
            const scenarios = [
                { context: "A fair coin is flipped twice", event: "getting two heads", p1: { num: 1, den: 2 }, p2: { num: 1, den: 2 } },
                { context: "A fair coin is flipped twice", event: "getting two tails", p1: { num: 1, den: 2 }, p2: { num: 1, den: 2 } },
                { context: "Two fair dice are rolled", event: "getting two 6s", p1: { num: 1, den: 6 }, p2: { num: 1, den: 6 } },
                { context: "A fair dice is rolled and a coin is flipped", event: "getting a 6 and heads", p1: { num: 1, den: 6 }, p2: { num: 1, den: 2 } },
                { context: "A fair coin is flipped three times", event: "getting three heads", p1: { num: 1, den: 2 }, p2: { num: 1, den: 2 }, p3: { num: 1, den: 2 } }
            ];
            
            const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
            let finalNum = scenario.p1.num * scenario.p2.num;
            let finalDen = scenario.p1.den * scenario.p2.den;
            if (scenario.p3) {
                finalNum *= scenario.p3.num;
                finalDen *= scenario.p3.den;
            }
            
            const simplified = y9es_k7m3_simplifyFraction(finalNum, finalDen);
            
            return {
                q: `<span class="q-block">${scenario.context}.</span><span class="q-block">What is the probability of ${scenario.event}?</span>`,
                a: `\\( \\frac{${simplified.num}}{${simplified.den}} \\)`,
                w: [
                    { text: "For independent events, multiply the probabilities:", math: `P = \\frac{${scenario.p1.num}}{${scenario.p1.den}} \\times \\frac{${scenario.p2.num}}{${scenario.p2.den}}` + (scenario.p3 ? ` \\times \\frac{${scenario.p3.num}}{${scenario.p3.den}}` : '') },
                    { text: "Calculate:", math: `P = \\frac{${finalNum}}{${finalDen}}` + (finalNum !== simplified.num ? ` = \\frac{${simplified.num}}{${simplified.den}}` : '') }
                ]
            };
        }
    },
    
    // ═══ CATEGORY 11: Sequences ═══
    {
        id: 32,
        category: "Sequences",
        title: "Find the nth term (linear)",
        description: "Find the nth term rule for an arithmetic sequence.",
        generator: () => {
            const isDescending = Math.random() < 0.33;
            
            let d, first;
            if (isDescending) {
                d = -(Math.floor(Math.random() * 6) + 2);
                first = Math.floor(Math.random() * 20) + 25;
            } else {
                d = Math.floor(Math.random() * 8) + 2;
                first = Math.floor(Math.random() * 15) + 1;
            }
            
            const terms = [first, first + d, first + 2*d, first + 3*d];
            
            if (terms.some(t => t <= 0)) {
                return y9es_k7m3_skills[32].generator();
            }
            
            const adjust = first - d;
            
            let answer;
            if (d > 0) {
                 if (adjust > 0) answer = `${d}n + ${adjust}`;
                 else if (adjust < 0) answer = `${d}n - ${Math.abs(adjust)}`;
                 else answer = `${d}n`;
            } else {
                 if (adjust > 0) answer = `${d}n + ${adjust}`;
                 else if (adjust < 0) answer = `${d}n - ${Math.abs(adjust)}`;
                 else answer = `${d}n`;
            }
            
            return {
                q: `<span class="q-block">Find the nth term of</span><span class="q-block">\\( ${terms.join(', ')}, ... \\)</span>`,
                a: `\\( ${answer} \\)`,
                w: [
                    { text: "Find the common difference:", math: `d = ${terms[1]} - ${terms[0]} = ${d}` },
                    { text: "The nth term starts as dn:", math: `${d}n` },
                    { text: "Compare: when n = 1, " + d + "n = " + d + ", but we need " + first + ":", math: `${first} - (${d}) = ${adjust}` },
                    { text: "So the nth term is:", math: answer }
                ]
            };
        }
    },
    {
        id: 33,
        category: "Sequences",
        title: "Find a term from nth term rule",
        description: "Substitute into an nth term rule to find a specific term.",
        generator: () => {
            const isDescending = Math.random() < 0.33;
            
            let a;
            if (isDescending) {
                a = -(Math.floor(Math.random() * 5) + 2);
            } else {
                a = Math.floor(Math.random() * 7) + 2;
            }
            
            let b = Math.floor(Math.random() * 12) + 1;
            if (Math.random() < 0.5) b = -b;
            
            const n = Math.floor(Math.random() * 16) + 5;
            const answer = a * n + b;
            
            if (isDescending && answer < -100) {
                return y9es_k7m3_skills[33].generator();
            }
            
            let rule;
            if (a === -1) {
                rule = b >= 0 ? `-n + ${b}` : `-n - ${Math.abs(b)}`;
            } else if (a === 1) {
                rule = b >= 0 ? `n + ${b}` : `n - ${Math.abs(b)}`;
            } else {
                rule = b >= 0 ? `${a}n + ${b}` : `${a}n - ${Math.abs(b)}`;
            }
            
            return {
                q: `<span class="q-block">The nth term of a sequence is \\( ${rule} \\).</span><span class="q-block">Find the ${n}th term</span>`,
                a: `${answer}`,
                w: [
                    { text: "Substitute n = " + n + " into the rule:", math: `${a} \\times ${n} ${b >= 0 ? '+' : '-'} ${Math.abs(b)}` },
                    { text: "Calculate:", math: `${a * n} ${b >= 0 ? '+' : '-'} ${Math.abs(b)} = ${answer}` }
                ]
            };
        }
    },
    {
        id: 34,
        category: "Sequences",
        title: "Continue an arithmetic sequence",
        description: "Continue an arithmetic sequence by identifying the common difference.",
        generator: () => {
            const isDescending = Math.random() < 0.33;
            let d, first;
            
            if (isDescending) {
                d = -(Math.floor(Math.random() * 10) + 3);
                first = Math.floor(Math.random() * 50) + 40;
            } else {
                d = Math.floor(Math.random() * 13) + 3;
                first = Math.floor(Math.random() * 29) + 2;
            }
            
            const terms = [first, first + d, first + 2*d, first + 3*d];
            const next1 = first + 4*d;
            const next2 = first + 5*d;
            
            if (next2 <= 0) {
                return y9es_k7m3_skills[34].generator();
            }
            
            return {
                q: `<span class="q-block">Write the next two terms:</span><span class="q-block">\\( ${terms.join(', ')}, ... \\)</span>`,
                a: `${next1}, ${next2}`,
                w: [
                    { text: "Find the common difference:", math: `d = ${terms[1]} - ${terms[0]} = ${d}` },
                    { text: "Add the difference to get the next term:", math: `${terms[3]} + (${d}) = ${next1}` },
                    { text: "Add again for the term after:", math: `${next1} + (${d}) = ${next2}` }
                ]
            };
        }
    },
    
    // ═══ NEW SKILL: Angles around a point ═══
    {
        id: 35,
        category: "Geometry: Angles",
        title: "Angles around a point",
        description: "Find the missing angle using angles around a point summing to 360°.",
        generator: () => {
            const numGiven = Math.floor(Math.random() * 3) + 2;
            const answer = (Math.floor(Math.random() * 25) + 6) * 5;
            
            let givenAngles = [];
            let remaining = 360 - answer;
            
            if (numGiven === 2) {
                const ang1 = (Math.floor(Math.random() * 20) + 8) * 5;
                const ang2 = remaining - ang1;
                if (ang2 < 30 || ang2 > 180) {
                    return y9es_k7m3_skills[35].generator();
                }
                givenAngles = [ang1, ang2];
            } else if (numGiven === 3) {
                const ang1 = (Math.floor(Math.random() * 12) + 6) * 5;
                const ang2 = (Math.floor(Math.random() * 12) + 6) * 5;
                const ang3 = remaining - ang1 - ang2;
                if (ang3 < 30 || ang3 > 180) {
                    return y9es_k7m3_skills[35].generator();
                }
                givenAngles = [ang1, ang2, ang3];
            } else {
                givenAngles = [remaining];
            }
            
            const givenSum = givenAngles.reduce((a, b) => a + b, 0);
            const anglesStr = givenAngles.map(a => a + '°').join(', ');
            
            return {
                q: `<span class="q-block">Angles around a point are \\( x \\)° and ${anglesStr}.</span><span class="q-block">Find \\( x \\)</span>`,
                a: `${answer}°`,
                w: [
                    { text: "Angles around a point sum to 360°:", math: `x + ${givenAngles.join(' + ')} = 360` },
                    { text: "Add the given angles:", math: `x + ${givenSum} = 360` },
                    { text: "Subtract from 360°:", math: `x = 360 - ${givenSum} = ${answer}` }
                ]
            };
        }
    },
    
    // ═══ NEW SKILL: Find total given one gets more ═══
    {
        id: 36,
        category: "Ratio and proportion",
        title: "Find total given one gets more",
        description: "Find the total or other share when given the difference between shares.",
        generator: () => {
            let a, b;
            do {
                a = Math.floor(Math.random() * 7) + 3;
                b = Math.floor(Math.random() * (a - 1)) + 1;
            } while (a === b || !y9es_k7m3_areCoprime(a, b));
            
            const diff = a - b;
            const multiplier = Math.floor(Math.random() * 15) + 2;
            const moneyDiff = diff * multiplier;
            
            const moShare = a * multiplier;
            const joShare = b * multiplier;
            const total = (a + b) * multiplier;
            
            const askForTotal = Math.random() < 0.5;
            
            let question, answer, working;
            
            if (askForTotal) {
                question = `<span class="q-block">Mo and Jo share money in the ratio ${a} : ${b}.</span><span class="q-block">Mo gets £${moneyDiff} more than Jo. Find the total shared</span>`;
                answer = `£${total}`;
                working = [
                    { text: "The difference in ratio parts is:", math: `${a} - ${b} = ${diff} \\text{ parts}` },
                    { text: diff + " parts = £" + moneyDiff + ", so 1 part =:", math: `£${moneyDiff} \\div ${diff} = £${multiplier}` },
                    { text: "Total parts = " + (a + b) + ", so total is:", math: `${a + b} \\times ${multiplier} = £${total}` }
                ];
            } else {
                question = `<span class="q-block">Mo and Jo share money in the ratio ${a} : ${b}.</span><span class="q-block">Mo gets £${moneyDiff} more than Jo. How much does Jo get?</span>`;
                answer = `£${joShare}`;
                working = [
                    { text: "The difference in ratio parts is:", math: `${a} - ${b} = ${diff} \\text{ parts}` },
                    { text: diff + " parts = £" + moneyDiff + ", so 1 part =:", math: `£${moneyDiff} \\div ${diff} = £${multiplier}` },
                    { text: "Jo gets " + b + " parts:", math: `${b} \\times ${multiplier} = £${joShare}` }
                ];
            }
            
            return { q: question, a: answer, w: working };
        }
    }
];

// ─── MENU FUNCTIONS ──────────────────────────────────────────────
window.y9es_k7m3_showMenu = function() {
    y9es_k7m3_state.currentView = 'menu';
    y9es_k7m3_state.selectedSkills = [];
    y9es_k7m3_state.timer.isRunning = false;
    y9es_k7m3_state.timer.isPaused = false;
    clearInterval(y9es_k7m3_state.timer.intervalId);
    y9es_k7m3_updateTimerVisibility();
    
    document.getElementById('y9es_k7m3-menu-screen').style.display = 'block';
    document.getElementById('y9es_k7m3-question-screen').style.display = 'none';
    document.getElementById('y9es_k7m3-fullscreen-container').style.display = 'none';
    
    document.querySelectorAll('#y9es_k7m3-container .skill-card').forEach(card => card.classList.remove('selected'));
    document.getElementById('y9es_k7m3-go-btn').disabled = true;
    
    setTimeout(() => { y9es_k7m3_renderMath(document.getElementById('y9es_k7m3-menu-screen')); }, 100);
};

window.y9es_k7m3_toggleSkill = function(index, element) {
    const skillIndex = y9es_k7m3_state.selectedSkills.indexOf(index);
    if (skillIndex === -1) {
        y9es_k7m3_state.selectedSkills.push(index);
        element.classList.add('selected');
    } else {
        y9es_k7m3_state.selectedSkills.splice(skillIndex, 1);
        element.classList.remove('selected');
    }
    document.getElementById('y9es_k7m3-go-btn').disabled = y9es_k7m3_state.selectedSkills.length === 0;
};

window.y9es_k7m3_selectAllSkills = function() {
    y9es_k7m3_state.selectedSkills = y9es_k7m3_skills.map(s => s.id);
    document.querySelectorAll('#y9es_k7m3-container .skill-card').forEach(card => card.classList.add('selected'));
    document.getElementById('y9es_k7m3-go-btn').disabled = false;
};

window.y9es_k7m3_deselectAllSkills = function() {
    y9es_k7m3_state.selectedSkills = [];
    document.querySelectorAll('#y9es_k7m3-container .skill-card').forEach(card => card.classList.remove('selected'));
    document.getElementById('y9es_k7m3-go-btn').disabled = true;
};

window.y9es_k7m3_toggleTimerInputs = function() {
    const chk = document.getElementById('y9es_k7m3-use-timer');
    const inputs = document.getElementById('y9es_k7m3-timer-inputs');
    inputs.style.visibility = chk.checked ? 'visible' : 'hidden';
};

// ─── QUESTION GENERATION ─────────────────────────────────────────
function y9es_k7m3_generateSingleQuestionData() {
    const randIndex = Math.floor(Math.random() * y9es_k7m3_state.selectedSkills.length);
    const skillId = y9es_k7m3_state.selectedSkills[randIndex];
    const skill = y9es_k7m3_skills.find(s => s.id === skillId);
    const data = skill.generator();
    return { ...data, skillId: skillId, showAnswer: false };
}

window.y9es_k7m3_generateQuestions = function() {
    y9es_k7m3_state.currentQuestions = [];
    y9es_k7m3_state.showAllAnswers = false;
    
    // Reset Show/Hide button text
    const showAllBtn = document.querySelectorAll(`button[onclick='y9es_k7m3_showAllAnswers()']`);
    showAllBtn.forEach(b => b.innerText = "Show All Answers");
    
    // Generate 8 unique questions with safety limit
    const generatedQuestions = new Set();
    for (let i = 0; i < 8; i++) {
        let retries = 0;
        let qData;
        do {
            qData = y9es_k7m3_generateSingleQuestionData();
            retries++;
        } while (generatedQuestions.has(qData.q) && retries < 20);
        generatedQuestions.add(qData.q);
        y9es_k7m3_state.currentQuestions.push(qData);
    }
    
    if (y9es_k7m3_state.currentView === 'fullscreen') {
        y9es_k7m3_renderGrid();
        y9es_k7m3_refreshFullscreenGrid();
    } else {
        y9es_k7m3_state.currentView = 'questions';
        document.getElementById('y9es_k7m3-menu-screen').style.display = 'none';
        document.getElementById('y9es_k7m3-question-screen').style.display = 'flex';
        y9es_k7m3_renderGrid();
        
        const container = document.getElementById('y9es_k7m3-container');
        const yOffset = container.getBoundingClientRect().top + window.pageYOffset - 100;
        window.scrollTo({top: yOffset, behavior: 'smooth'});
    }
    
    // Timer logic
    const useTimer = document.getElementById('y9es_k7m3-use-timer').checked;
    if (useTimer) {
        const mins = parseInt(document.getElementById('y9es_k7m3-timer-mins').value) || 0;
        const secs = parseInt(document.getElementById('y9es_k7m3-timer-secs').value) || 0;
        const total = (mins * 60) + secs;
        if (total > 0) {
            y9es_k7m3_state.timer.totalSeconds = total;
            y9es_k7m3_state.timer.remainingSeconds = total;
            y9es_k7m3_startTimer();
        } else {
            y9es_k7m3_state.timer.totalSeconds = 0;
        }
    } else {
        y9es_k7m3_state.timer.totalSeconds = 0;
        clearInterval(y9es_k7m3_state.timer.intervalId);
        y9es_k7m3_state.timer.isRunning = false;
    }
    
    y9es_k7m3_updateTimerVisibility();
    y9es_k7m3_updateTimerDisplays();
};

function y9es_k7m3_createQuestionHTML(index, qData) {
    const answerStyle = qData.showAnswer || y9es_k7m3_state.showAllAnswers ? 'display: block;' : 'display: none;';
    return `
    <div id="y9es_k7m3_qbox_${index}" class="question-box">
        <div class="box-header">
            <span style="font-weight:bold; color:#3498db; font-size:1.2em;">${index + 1}</span>
            <div class="icon-group">
                <div class="icon-btn" onclick="y9es_k7m3_regenerateSingleQuestion(${index})">↻</div>
                <div class="icon-btn" onclick="y9es_k7m3_toggleAnswer(${index})">👁</div>
                <div class="icon-btn" onclick="y9es_k7m3_openFocusBox(${index})">🔍</div>
            </div>
        </div>
        <div class="q-text">${qData.q}</div>
        <div id="y9es_k7m3_ans_${index}" class="answer-display" style="${answerStyle}">
            ${qData.a}
        </div>
    </div>`;
}

function y9es_k7m3_createFullscreenQuestionHTML(index, qData) {
    const showAns = qData.showAnswer || y9es_k7m3_state.showAllAnswers;
    const answerStyle = showAns ? 'display: flex;' : 'display: none;';
    return `
    <div id="y9es_k7m3_fs_qbox_${index}" class="fullscreen-question-box">
        <div class="fs-header">
            <span style="font-weight:bold; color:#3498db; font-size:1.2em;">${index + 1}</span>
            <div style="display:flex; gap:10px;">
                <div class="fs-icon" style="cursor:pointer;" onclick="y9es_k7m3_regenerateSingleQuestion(${index})">↻</div>
                <div class="fs-icon" style="cursor:pointer;" onclick="y9es_k7m3_toggleAnswer(${index})">👁</div>
                <div class="fs-icon" style="cursor:pointer;" onclick="y9es_k7m3_openFocusBox(${index})">🔍</div>
            </div>
        </div>
        <div class="fs-content-wrapper">
            ${qData.q}
        </div>
        <div id="y9es_k7m3_fs_ans_${index}" class="fs-answer" style="${answerStyle}">
            ${qData.a}
        </div>
    </div>`;
}

function y9es_k7m3_renderGrid() {
    const grid = document.getElementById('y9es_k7m3-question-grid');
    grid.innerHTML = y9es_k7m3_state.currentQuestions.map((q, i) => y9es_k7m3_createQuestionHTML(i, q)).join('');
    setTimeout(() => { y9es_k7m3_renderMath(grid); }, 50);
}

function y9es_k7m3_refreshFullscreenGrid() {
    const grid = document.getElementById('y9es_k7m3-fullscreen-grid');
    grid.innerHTML = y9es_k7m3_state.currentQuestions.map((q, i) => y9es_k7m3_createFullscreenQuestionHTML(i, q)).join('');
    setTimeout(() => { y9es_k7m3_renderMath(grid); }, 50);
}

window.y9es_k7m3_regenerateSingleQuestion = function(index) {
    const otherQuestions = new Set(
        y9es_k7m3_state.currentQuestions
            .filter((_, i) => i !== index)
            .map(q => q.q)
    );
    
    let retries = 0;
    let newData;
    do {
        newData = y9es_k7m3_generateSingleQuestionData();
        retries++;
    } while (otherQuestions.has(newData.q) && retries < 20);
    
    y9es_k7m3_state.currentQuestions[index] = newData;
    
    const qBox = document.getElementById(`y9es_k7m3_qbox_${index}`);
    if (qBox) {
        qBox.outerHTML = y9es_k7m3_createQuestionHTML(index, y9es_k7m3_state.currentQuestions[index]);
        setTimeout(() => y9es_k7m3_renderMath(document.getElementById(`y9es_k7m3_qbox_${index}`)), 10);
    }
    
    const fsBox = document.getElementById(`y9es_k7m3_fs_qbox_${index}`);
    if (fsBox) {
        fsBox.outerHTML = y9es_k7m3_createFullscreenQuestionHTML(index, y9es_k7m3_state.currentQuestions[index]);
        setTimeout(() => y9es_k7m3_renderMath(document.getElementById(`y9es_k7m3_fs_qbox_${index}`)), 10);
    }
};

window.y9es_k7m3_toggleAnswer = function(index) {
    y9es_k7m3_state.currentQuestions[index].showAnswer = !y9es_k7m3_state.currentQuestions[index].showAnswer;
    
    const el = document.getElementById(`y9es_k7m3_ans_${index}`);
    if (el) el.style.display = y9es_k7m3_state.currentQuestions[index].showAnswer ? 'block' : 'none';
    
    const fsEl = document.getElementById(`y9es_k7m3_fs_ans_${index}`);
    if (fsEl) fsEl.style.display = y9es_k7m3_state.currentQuestions[index].showAnswer ? 'flex' : 'none';
};

window.y9es_k7m3_showAllAnswers = function() {
    y9es_k7m3_state.showAllAnswers = !y9es_k7m3_state.showAllAnswers;
    
    y9es_k7m3_state.currentQuestions.forEach((q, i) => {
        if (y9es_k7m3_state.showAllAnswers) {
            document.getElementById(`y9es_k7m3_ans_${i}`).style.display = 'block';
            if (document.getElementById(`y9es_k7m3_fs_ans_${i}`)) {
                document.getElementById(`y9es_k7m3_fs_ans_${i}`).style.display = 'flex';
            }
        } else {
            document.getElementById(`y9es_k7m3_ans_${i}`).style.display = q.showAnswer ? 'block' : 'none';
            if (document.getElementById(`y9es_k7m3_fs_ans_${i}`)) {
                document.getElementById(`y9es_k7m3_fs_ans_${i}`).style.display = q.showAnswer ? 'flex' : 'none';
            }
        }
    });
    
    const btn = document.querySelectorAll("button[onclick='y9es_k7m3_showAllAnswers()']");
    btn.forEach(b => b.innerText = y9es_k7m3_state.showAllAnswers ? "Hide All Answers" : "Show All Answers");
};

// ─── FULLSCREEN ──────────────────────────────────────────────────
window.y9es_k7m3_enterFullscreen = function() {
    y9es_k7m3_state.currentView = 'fullscreen';
    document.getElementById('y9es_k7m3-fullscreen-container').style.display = 'block';
    y9es_k7m3_refreshFullscreenGrid();
    y9es_k7m3_updateTimerVisibility();
};

window.y9es_k7m3_exitFullscreen = function() {
    y9es_k7m3_state.currentView = 'questions';
    document.getElementById('y9es_k7m3-fullscreen-container').style.display = 'none';
    y9es_k7m3_updateTimerVisibility();
};

// ─── FOCUS BOX ───────────────────────────────────────────────────
window.y9es_k7m3_openFocusBox = function(index) {
    y9es_k7m3_state.focusBoxQuestion = index;
    y9es_k7m3_state.focusBoxShowAnswer = false;
    y9es_k7m3_state.focusBoxShowWorking = false;
    document.getElementById('y9es_k7m3-focus-overlay').style.display = 'block';
    document.getElementById('y9es_k7m3-focus-modal').style.display = 'block';
    y9es_k7m3_updateFocusBoxContent();
};

window.y9es_k7m3_closeFocusBox = function() {
    document.getElementById('y9es_k7m3-focus-overlay').style.display = 'none';
    document.getElementById('y9es_k7m3-focus-modal').style.display = 'none';
};

function y9es_k7m3_updateFocusBoxContent() {
    const idx = y9es_k7m3_state.focusBoxQuestion;
    const data = y9es_k7m3_state.currentQuestions[idx];
    const content = document.getElementById('y9es_k7m3-focus-content');
    
    let workingHTML = '';
    if (y9es_k7m3_state.focusBoxShowWorking) {
        workingHTML = '<div style="margin-top:20px; text-align:left;">';
        data.w.forEach((step, i) => {
            workingHTML += `
            <div style="margin-bottom:15px; padding-left:15px; border-left:3px solid #3498db;">
                <div style="font-weight:bold; color:#3498db;">Step ${i+1}</div>
                <div style="font-style:italic; color:#7f8c8d; margin-bottom:5px;">${step.text}</div>
                <div style="font-size:1.2em;">\\( ${step.math} \\)</div>
            </div>`;
        });
        workingHTML += `<div class="working-final-answer">${data.a}</div></div>`;
    }
    
    const answerHTML = y9es_k7m3_state.focusBoxShowAnswer ?
        `<div class="answer-display" style="display:block; margin-top:20px; width:100%; box-sizing:border-box;">${data.a}</div>` : '';
    
    const html = `<div style="font-size:1.6em; margin-bottom:20px; color:#2c3e50; text-align:center;">${data.q}</div>${answerHTML}${workingHTML}`;
    
    content.innerHTML = html;
    document.getElementById('y9es_k7m3-focus-title').innerText = `Question ${idx + 1}`;
    setTimeout(() => { y9es_k7m3_renderMath(content); }, 50);
}

window.y9es_k7m3_toggleFocusAnswer = function() {
    y9es_k7m3_state.focusBoxShowAnswer = !y9es_k7m3_state.focusBoxShowAnswer;
    y9es_k7m3_updateFocusBoxContent();
};

window.y9es_k7m3_toggleFocusWorking = function() {
    y9es_k7m3_state.focusBoxShowWorking = !y9es_k7m3_state.focusBoxShowWorking;
    y9es_k7m3_updateFocusBoxContent();
};

window.y9es_k7m3_regenerateFocusQuestion = function() {
    const idx = y9es_k7m3_state.focusBoxQuestion;
    y9es_k7m3_regenerateSingleQuestion(idx);
    y9es_k7m3_state.focusBoxShowAnswer = false;
    y9es_k7m3_state.focusBoxShowWorking = false;
    y9es_k7m3_updateFocusBoxContent();
};

window.y9es_k7m3_prevFocusQuestion = function() {
    y9es_k7m3_state.focusBoxQuestion = (y9es_k7m3_state.focusBoxQuestion - 1 + 8) % 8;
    y9es_k7m3_state.focusBoxShowAnswer = false;
    y9es_k7m3_state.focusBoxShowWorking = false;
    y9es_k7m3_updateFocusBoxContent();
};

window.y9es_k7m3_nextFocusQuestion = function() {
    y9es_k7m3_state.focusBoxQuestion = (y9es_k7m3_state.focusBoxQuestion + 1) % 8;
    y9es_k7m3_state.focusBoxShowAnswer = false;
    y9es_k7m3_state.focusBoxShowWorking = false;
    y9es_k7m3_updateFocusBoxContent();
};

// ─── TIMER ───────────────────────────────────────────────────────
function y9es_k7m3_startTimer() {
    if (y9es_k7m3_state.timer.intervalId) clearInterval(y9es_k7m3_state.timer.intervalId);
    y9es_k7m3_state.timer.isRunning = true;
    y9es_k7m3_state.timer.isPaused = false;
    y9es_k7m3_state.timer.intervalId = setInterval(() => {
        if (y9es_k7m3_state.timer.remainingSeconds > 0) {
            y9es_k7m3_state.timer.remainingSeconds--;
            y9es_k7m3_updateTimerDisplays();
        } else {
            y9es_k7m3_timerExpired();
        }
    }, 1000);
    y9es_k7m3_updateTimerButtons();
}

window.y9es_k7m3_pauseTimer = function() {
    y9es_k7m3_state.timer.isPaused = true;
    y9es_k7m3_state.timer.isRunning = false;
    clearInterval(y9es_k7m3_state.timer.intervalId);
    y9es_k7m3_updateTimerButtons();
};

window.y9es_k7m3_resumeTimer = function() {
    y9es_k7m3_startTimer();
};

window.y9es_k7m3_resetTimer = function() {
    clearInterval(y9es_k7m3_state.timer.intervalId);
    y9es_k7m3_state.timer.remainingSeconds = y9es_k7m3_state.timer.totalSeconds;
    y9es_k7m3_state.timer.isRunning = false;
    y9es_k7m3_state.timer.isPaused = false;
    y9es_k7m3_state.timer.isFlashing = false;
    document.getElementById('y9es_k7m3-timer-display').classList.remove('flashing');
    document.getElementById('y9es_k7m3-fs-timer-display').classList.remove('flashing');
    y9es_k7m3_updateTimerDisplays();
    y9es_k7m3_updateTimerButtons();
};

function y9es_k7m3_timerExpired() {
    clearInterval(y9es_k7m3_state.timer.intervalId);
    y9es_k7m3_state.timer.isRunning = false;
    y9es_k7m3_state.timer.isFlashing = true;
    document.getElementById('y9es_k7m3-timer-display').classList.add('flashing');
    document.getElementById('y9es_k7m3-fs-timer-display').classList.add('flashing');
    y9es_k7m3_updateTimerButtons();
}

function y9es_k7m3_updateTimerDisplays() {
    const m = Math.floor(y9es_k7m3_state.timer.remainingSeconds / 60);
    const s = y9es_k7m3_state.timer.remainingSeconds % 60;
    const text = `${m}:${s < 10 ? '0' : ''}${s}`;
    document.querySelectorAll('.y9es_k7m3-timer-text').forEach(span => span.innerText = text);
}

function y9es_k7m3_updateTimerButtons() {
    const containers = [
        document.getElementById('y9es_k7m3-timer-controls'),
        document.getElementById('y9es_k7m3-fs-timer-controls')
    ];
    containers.forEach(cont => {
        if (!cont) return;
        const btnStart = cont.querySelector('.timer-start');
        const btnPause = cont.querySelector('.timer-pause');
        if (y9es_k7m3_state.timer.isRunning) {
            btnStart.style.display = 'none';
            btnPause.style.display = 'inline-block';
        } else {
            btnStart.style.display = 'inline-block';
            btnPause.style.display = 'none';
        }
    });
}

function y9es_k7m3_updateTimerVisibility() {
    const normalTimer = document.getElementById('y9es_k7m3-timer-display');
    const fsTimer = document.getElementById('y9es_k7m3-fs-timer-display');
    
    if (y9es_k7m3_state.timer.totalSeconds > 0) {
        if (y9es_k7m3_state.currentView === 'questions') {
            normalTimer.style.setProperty('display', 'flex', 'important');
            fsTimer.style.setProperty('display', 'none', 'important');
        } else if (y9es_k7m3_state.currentView === 'fullscreen') {
            normalTimer.style.setProperty('display', 'none', 'important');
            fsTimer.style.setProperty('display', 'inline-flex', 'important');
        } else {
            normalTimer.style.setProperty('display', 'none', 'important');
            fsTimer.style.setProperty('display', 'none', 'important');
        }
    } else {
        normalTimer.style.setProperty('display', 'none', 'important');
        fsTimer.style.setProperty('display', 'none', 'important');
    }
}

// ─── WORKSHEET GENERATION ────────────────────────────────────────
window.y9es_k7m3_generateWorksheet = function() {
    const printContainer = document.getElementById('y9es_k7m3-print-container');
    
    // Relocate to body if needed
    if (printContainer.parentNode !== document.body) {
        document.body.appendChild(printContainer);
    }
    
    let html = '';
    
    // Page 1: Questions
    html += '<div class="print-page">';
    html += '<div class="print-header">';
    html += '<h1>Super 8s: Year 9 Essential Skills by Mr Barton Maths</h1>';
    html += '<p>Name: _________________________ Date: _____________</p>';
    html += '</div>';
    html += '<div class="print-grid">';
    
    y9es_k7m3_state.currentQuestions.forEach((q, i) => {
        html += `
        <div class="print-question-box">
            <div class="print-q-num">${i + 1}</div>
            <div class="print-q-content">${q.q}</div>
            <div class="print-working-space">
                <div class="answer-line">
                    <span class="answer-label">Answer:</span>
                    <span class="answer-rule"></span>
                </div>
            </div>
        </div>`;
    });
    
    html += '</div></div>';
    
    // Page 2: Answer Key
    html += '<div class="print-page">';
    html += '<div class="print-header"><h1>Answer Key</h1></div>';
    html += '<div class="print-answer-list">';
    
    y9es_k7m3_state.currentQuestions.forEach((q, i) => {
        html += `<div class="print-answer-item"><strong>${i + 1}.</strong> ${q.a}</div>`;
    });
    
    html += '</div></div>';
    
    printContainer.innerHTML = html;
    
    y9es_k7m3_renderMath(printContainer);
    
    setTimeout(() => {
        window.print();
    }, 500);
};

// ─── MATHJAX ─────────────────────────────────────────────────────
function y9es_k7m3_initializeWithMathJax(callback, retries = 0) {
    if (typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
        callback();
        MathJax.typesetPromise().catch(e => {});
    } else if (typeof MathJax !== 'undefined' && MathJax.Hub) {
        callback();
        MathJax.Hub.Queue(["Typeset", MathJax.Hub]);
    } else if (retries < 30) {
        setTimeout(() => y9es_k7m3_initializeWithMathJax(callback, retries + 1), 100);
    } else {
        callback();
    }
}

function y9es_k7m3_renderMath(element = null) {
    if (typeof MathJax === 'undefined') return;
    if (MathJax.typesetPromise) {
        const target = element ? [element] : null;
        MathJax.typesetPromise(target).catch(e => {
            if (element && MathJax.typesetClear) {
                try { MathJax.typesetClear([element]); } catch (e) {}
            }
            MathJax.typesetPromise(target).catch(e => {});
        });
    } else if (MathJax.Hub) {
        MathJax.Hub.Queue(["Typeset", MathJax.Hub, element]);
    }
}

// ─── INITIALIZATION ──────────────────────────────────────────────
y9es_k7m3_initializeWithMathJax(() => {
    console.log('Super 8s: Year 9 Essential Skills initialized');
});


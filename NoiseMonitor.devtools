                    <div class="vnl-emoji-alarm">🤫</div>
                    <h2>TOO LOUD!</h2>
                </div>
            </div>
        </div>

        <!-- Controls Toolbar -->
        <div class="vnl-controls">
            
            <div class="vnl-control-group">
                <label>Microphone Sensitivity</label>
                <input type="range" id="vnl-in-sensitivity" min="0" max="100" value="50">
            </div>

            <div class="vnl-control-group">
                <label>Max Volume Limit</label>
                <input type="range" id="vnl-in-threshold" min="10" max="95" value="70">
            </div>

            <button id="vnl-btn-stop" class="vnl-btn-secondary">Stop</button>
        </div>
    </div>

</div>

<style>
#VisualNoiseLevel_7xR9p {
    --vnl-bg: #f8fafc;
    --vnl-text: #334155;
    --vnl-calm: #10b981;  /* Green */
    --vnl-warn: #f59e0b;  /* Orange */
    --vnl-loud: #ef4444;  /* Red */
    --vnl-font: 'Segoe UI', system-ui, sans-serif;
    
    font-family: var(--vnl-font);
    background: var(--vnl-bg);
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    max-width: 800px;
    margin: 20px auto;
    overflow: hidden;
    position: relative;
    color: var(--vnl-text);
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    height: 600px;
    display: flex;
    flex-direction: column;
}

#VisualNoiseLevel_7xR9p:fullscreen {
    max-width: 100%;
    height: 100vh;
    border-radius: 0;
    border: none;
}

/* Header */
#VisualNoiseLevel_7xR9p .vnl-header { display: flex; justify-content: space-between; align-items: center; padding: 15px 25px; background: white; border-bottom: 1px solid #e2e8f0; z-index: 20; }
#VisualNoiseLevel_7xR9p .vnl-header-left { display: flex; align-items: center; gap: 10px; }
#VisualNoiseLevel_7xR9p .vnl-title { margin: 0; font-size: 1.25rem; font-weight: 700; color: #1e293b; }
#VisualNoiseLevel_7xR9p .vnl-icon-btn { background: none; border: none; cursor: pointer; color: #64748b; padding: 5px; }
#VisualNoiseLevel_7xR9p .vnl-icon-btn:hover { color: var(--vnl-text); }

/* Views */
#VisualNoiseLevel_7xR9p .vnl-view { display: none; flex: 1; position: relative; width: 100%; height: 100%; }
#VisualNoiseLevel_7xR9p .vnl-view.active { display: flex; flex-direction: column; }

/* Start Screen */
#VisualNoiseLevel_7xR9p #vnl-view-start { align-items: center; justify-content: center; text-align: center; padding: 20px; }
#VisualNoiseLevel_7xR9p .vnl-permission-card { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); max-width: 400px; }
#VisualNoiseLevel_7xR9p .vnl-emoji-hero { font-size: 4rem; margin-bottom: 10px; animation: vnl-wave 2s infinite; }
#VisualNoiseLevel_7xR9p .vnl-btn-primary { background: #3b82f6; color: white; border: none; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 1.1rem; cursor: pointer; margin-top: 20px; transition: transform 0.1s; }
#VisualNoiseLevel_7xR9p .vnl-btn-primary:hover { background: #2563eb; transform: translateY(-2px); }

/* Monitor Stage */
#VisualNoiseLevel_7xR9p .vnl-stage { flex: 1; position: relative; background: #e0f2fe; display: flex; justify-content: center; overflow: hidden; transition: background 0.3s; }
#VisualNoiseLevel_7xR9p .vnl-stage.stage-warn { background: #ffedd5; }
#VisualNoiseLevel_7xR9p .vnl-stage.stage-loud { background: #fee2e2; }

/* Emoji */
#VisualNoiseLevel_7xR9p .vnl-emoji-main { position: absolute; top: 15%; left: 50%; transform: translateX(-50%); font-size: 6rem; z-index: 5; text-shadow: 0 4px 10px rgba(0,0,0,0.1); transition: transform 0.1s; }

/* Meter */
#VisualNoiseLevel_7xR9p .vnl-meter-container { width: 120px; height: 100%; position: relative; z-index: 1; }
#VisualNoiseLevel_7xR9p .vnl-meter-bg { width: 100%; height: 100%; background: rgba(255,255,255,0.3); border-left: 2px solid rgba(0,0,0,0.05); border-right: 2px solid rgba(0,0,0,0.05); position: relative; }
#VisualNoiseLevel_7xR9p .vnl-meter-fill { position: absolute; bottom: 0; left: 0; width: 100%; height: 0%; background: var(--vnl-calm); transition: height 0.1s ease-out, background 0.3s; opacity: 0.8; box-shadow: 0 0 20px var(--vnl-calm); }
#VisualNoiseLevel_7xR9p .vnl-limit-line { position: absolute; bottom: 70%; left: -20%; width: 140%; height: 2px; background: #334155; border-bottom: 2px dashed rgba(255,255,255,0.5); z-index: 10; pointer-events: none; }
#VisualNoiseLevel_7xR9p .vnl-limit-line span { position: absolute; right: 0; bottom: 4px; font-size: 0.7rem; font-weight: bold; background: #334155; color: white; padding: 2px 6px; border-radius: 4px; }

/* Alarm Overlay */
#VisualNoiseLevel_7xR9p .vnl-alarm-overlay { position: absolute; inset: 0; background: rgba(220, 38, 38, 0.9); display: flex; align-items: center; justify-content: center; z-index: 50; opacity: 0; pointer-events: none; transition: opacity 0.1s; backdrop-filter: blur(2px); }
#VisualNoiseLevel_7xR9p .vnl-alarm-overlay.active { opacity: 1; pointer-events: auto; animation: vnl-flash 0.5s infinite; }
#VisualNoiseLevel_7xR9p .vnl-alarm-content { text-align: center; color: white; transform: scale(0.8); transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
#VisualNoiseLevel_7xR9p .vnl-alarm-overlay.active .vnl-alarm-content { transform: scale(1); }
#VisualNoiseLevel_7xR9p .vnl-emoji-alarm { font-size: 8rem; }
#VisualNoiseLevel_7xR9p .vnl-alarm-content h2 { font-size: 3rem; margin: 0; text-transform: uppercase; font-weight: 900; letter-spacing: 2px; }

/* Controls */
#VisualNoiseLevel_7xR9p .vnl-controls { background: white; padding: 15px 20px; border-top: 1px solid #e2e8f0; display: flex; gap: 20px; align-items: center; justify-content: space-between; z-index: 20; }
#VisualNoiseLevel_7xR9p .vnl-control-group { flex: 1; display: flex; flex-direction: column; }
#VisualNoiseLevel_7xR9p .vnl-control-group label { font-size: 0.8rem; font-weight: 700; color: #64748b; margin-bottom: 5px; }
#VisualNoiseLevel_7xR9p input[type="range"] { width: 100%; accent-color: #3b82f6; cursor: pointer; }
#VisualNoiseLevel_7xR9p .vnl-btn-secondary { background: #f1f5f9; border: none; padding: 8px 16px; border-radius: 6px; color: #475569; font-weight: 600; cursor: pointer; }
